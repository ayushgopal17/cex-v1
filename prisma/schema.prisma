// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model User {
  id           String @default(uuid())
  username     String @unique
  password     String
}

model Order {
  id        String      @default(uuid())
  name      String
  symbol    String  @unique 
}

model Fill {

  id String @unique
  userId String
  market String
  quantity Int
  type String
  side String
  fillQty Int
  status String
  createdAt String

}

model stock {

  id String @unique
  quantity Int
  side String
  type String
  userId String
  price Float
  asset String
  originalId String
  createdAt String
}